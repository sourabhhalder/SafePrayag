# Copy to .env and fill your own values locally or in Render.
# Never commit real secrets to GitHub.

MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
SECRET_KEY=replace_with_a_long_random_secret

# Fast2SMS
FAST2SMS_API_KEY=

# Telegram Bot notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp Cloud API notifications
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=

# Frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://safeprayag-frontend.vercel.app,https://safeprayag.vercel.app
