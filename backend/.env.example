# Copy to .env and fill values

# MongoDB Atlas free tier — get from https://cloud.mongodb.com
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/safeprayag?retryWrites=true&w=majority

# Strong random secret key for JWT
SECRET_KEY=your_very_long_random_secret_key_here_change_this

# Fast2SMS free SMS API for India — get from https://www.fast2sms.com
# Set this only in Render/local env files, not in Git-tracked source files.
# Leave blank to run in simulation mode (logs to console)
FAST2SMS_API_KEY=

# Frontend origin (update after Vercel deploy)
ALLOWED_ORIGINS=http://localhost:3000,https://safeprayag-frontend.vercel.app,https://safeprayag.vercel.app
